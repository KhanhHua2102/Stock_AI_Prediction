# FINA Suite Environment Configuration
# Copy this file to .env and fill in your actual API keys

FS_API_KEY=your-internal-api-key-here
FS_LLM_API_BASE=http://localhost:20128/v1
FS_LLM_API_KEY=your-llm-api-key-here
FS_LLM_MODEL=Stock-Analysis

# Phase 2 API keys
FS_FINNHUB_API_KEY=your-finnhub-api-key
FS_FRED_API_KEY=your-fred-api-key
FS_TWELVEDATA_API_KEY=your-twelvedata-api-key

# Phase 3 API keys
FS_FMP_API_KEY=your-fmp-api-key
FS_POLYGON_API_KEY=your-polygon-api-key
